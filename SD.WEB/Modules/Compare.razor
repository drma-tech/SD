            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Justify" Class="mb-2">
                Most solutions focus on a single aspect of discovery. Some list availability, others promote their own catalogs, and some provide limited ratings or reviews.
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Justify" Class="mb-2">
                Streaming Discovery combines availability, aggregated ratings, expert reviews, curated lists, and real-time trends into a structured decision layer for what to watch.
            </MudText>
        </BodyFragment>
    </PageSectionComponent>
    <PageSectionComponent Title="Comparison Overview" Subtitle="Different platforms solve different parts of content discovery.">
        <BodyFragment>
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Medium("mb")">
                <MudItem xs="3"><MudText Typo="Typo.h6" Color="Color.Primary">Feature</MudText></MudItem>
                <MudItem xs="3"><MudText Typo="Typo.h6" Color="Color.Primary">Streaming Platforms</MudText></MudItem>
                <MudItem xs="3"><MudText Typo="Typo.h6" Color="Color.Primary">Other Aggregators</MudText></MudItem>
                <MudItem xs="3"><MudText Typo="Typo.h6" Color="Color.Primary">Streaming Discovery</MudText></MudItem>
            </MudGrid>
            <!-- Availability -->
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Small("mb")">
                <MudItem xs="3"><MudText>Where to Watch</MudText></MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-frown").Font" Color="Color.Error" />
                    <MudText Inline="true">Own catalog only</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Supported</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-smile").Font" Color="Color.Success" />
                    <MudText Inline="true">Global, structured</MudText>
                </MudItem>
            </MudGrid>
            <!-- Ratings -->
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Small("mb")">
                <MudItem xs="3"><MudText>Ratings Sources</MudText></MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-frown").Font" Color="Color.Error" />
                    <MudText Inline="true">Internal only</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Few sources</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-smile").Font" Color="Color.Success" />
                    <MudText Inline="true">Multiple aggregated sources</MudText>
                </MudItem>
            </MudGrid>
            <!-- Reviews -->
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Small("mb")">
                <MudItem xs="3"><MudText>Expert Reviews</MudText></MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-frown").Font" Color="Color.Error" />
                    <MudText Inline="true">Rare</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Limited</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-smile").Font" Color="Color.Success" />
                    <MudText Inline="true">Multiple expert sources</MudText>
                </MudItem>
            </MudGrid>
            <!-- Discovery -->
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Small("mb")">
                <MudItem xs="3"><MudText>Discovery Tools</MudText></MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Limited filtering</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Single-platform browsing</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-smile").Font" Color="Color.Success" />
                    <MudText Inline="true">Multi-source, structured discovery</MudText>
                </MudItem>
            </MudGrid>
            <!-- Lists -->
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Small("mb")">
                <MudItem xs="3"><MudText>Curated Lists</MudText></MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Platform-driven</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
