                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-smile").Font" Color="Color.Success" />
                    <MudText Inline="true">Popular, awards, editor’s choice</MudText>
                </MudItem>
            </MudGrid>
            <!-- Regional -->
            <MudGrid Spacing="@Css.SpaceMedium" Class="@Css.Build().Small("mb")">
                <MudItem xs="3"><MudText>Regional Insights</MudText></MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-frown").Font" Color="Color.Error" />
                    <MudText Inline="true">Region-locked catalogs</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-meh").Font" Color="Color.Warning" />
                    <MudText Inline="true">Partial regional coverage</MudText>
                </MudItem>
                <MudItem xs="3">
                    <MudIcon Icon="@IconsFA.Solid.Icon("face-smile").Font" Color="Color.Success" />
