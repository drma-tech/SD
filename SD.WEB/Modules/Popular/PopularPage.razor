@page "/{culture}/popular/{type}"

@inherits PageCore<PopularPage>

@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Modules.Profile.Core

@inject ImdbPopularApi ImdbPopularApi
@inject WatchingListApi WatchingApi
@inject WishListApi WishApi

<HeadComponent Title="@($"{Translations.Module.Media.Popular} ({PopularType.GetName()})")"
               Description="@Translations.Description.PopularIndex.Format(PopularType.GetName())" Url="@($"/{Culture}/popular/{Type}")" Index="true" Shared="true" />
<PageSectionComponent IsPageHeader="true" Title="@($"{Translations.Module.Media.Popular} ({PopularType.GetName()})")"
                      Description="@Translations.Description.PopularIndex.Format(PopularType.GetName())" UrlShare="@($"/{Culture}/popular/{Type}")" />

@if (PopularType == PopularType.Movie)
{
    <MediaListFull MediaListApi="ImdbPopularApi" IsImdb="true" OnlyYear="true" Watching="Watching" Wish="Wish" StringParameters="Params" TypeSelected="MediaType.movie"
                   FullPage="true" ShowHead="false" Culture="@Culture">
    </MediaListFull>
}
else
{
    <MediaListFull MediaListApi="ImdbPopularApi" IsImdb="true" OnlyYear="true" Watching="Watching" Wish="Wish" StringParameters="Params" TypeSelected="MediaType.tv"
                   FullPage="true" ShowHead="false" Culture="@Culture">
    </MediaListFull>
}

@code {
    [Parameter] public string? Type { get; set; }

    public PopularType PopularType => Type.ParseToEnum(PopularType.Movie);

    public WatchingList? Watching { get; set; }
    public WishList? Wish { get; set; }

    public Dictionary<string, string> Params { get; set; } = new() { { "mode", "full" } };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        WatchingApi.DataChanged += model => { Watching = model; StateHasChanged(); };
        WishApi.DataChanged += model => { Wish = model; StateHasChanged(); };
    }
}
