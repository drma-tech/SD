@page "/{culture}/platform/{id}"

@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Modules.Platform.Core
@using SD.WEB.Modules.Profile.Core
@using SD.WEB.Modules.Subscription.Core
@using SD.WEB.Shared.Core
@inherits PageCore<PlataformDetail>

@inject AllProvidersApi AllProvidersApi
@inject TmdbDiscoveryApi TmdbDiscoveryApi
@inject WatchingListApi WatchingApi
@inject WishListApi WishApi
@inject MyProvidersApi MyProvidersApi
@inject IpInfoApi IpInfoApi

@if (isNotFound)
{
    <NotFoundComponent></NotFoundComponent>
}
else
{
    <HeadComponent Title="@Translations.Title.PlatformDetail.Format(Provider?.name)" Description="@Provider?.description" Url="@($"/{Culture}/platform/{Provider?.id}")" Image="@(TmdbOptions.OriginalPosterPath + Provider?.logo_path)" Index="true" Shared="true" />

    @if (Provider != null)
    {
        <PageSectionComponent IsPageHeader="true" Image="@(TmdbOptions.OriginalPosterPath + Provider.logo_path)" Title="@Provider.name" Subtitle="@GetSubtitle()" Description="@Provider.description"
                              UrlShare="@($"/{Culture}/platform/{Provider.id}")">
            <ActionsFragment>
                <div>
                    <MudSelect T="Country?" Value="SelectedRegion" ValueChanged="SelectedRegionChanged" Label="@Translations.Module.Media.Region" Variant="Variant.Text" Dense="true" Class="me-2" Style="width: 150px;">
                        @foreach (var item in regions.OrderBy(p => p.Name))
                        {
                            <MudSelectItem Value="@((Country?)item.Value)">@item.Name</MudSelectItem>
                        }
                    </MudSelect>
                </div>
                @if (Provider.link.NotEmpty() && Platform != SD.Shared.Enums.Platform.huawei)
                {
                    <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Link" OnClick="@(() => OpenExternalWebsite(Provider.link))" Class="me-2" Variant="Variant.Filled">
                        @Translations.Module.Media.OfficialWebsite
                    </MudButton>
                }
                @if (Provider != null)
                {
                    @if (MyProviders?.Items.Any(a => a.id == Provider?.id) ?? false)
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.Remove" Color="Color.Error" OnClick="@Remove" Variant="Variant.Filled" Class="me-2">
                            @Translations.Button.Remove
                        </MudButton>
                    }
                    else
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@Add" Variant="Variant.Filled" Class="me-2">
                            @Translations.Button.Add
                        </MudButton>
                    }
                }
            </ActionsFragment>
        </PageSectionComponent>
    }

    <RenderControl Actions="Actions">
        <MediaListComponent ContainsHeader="true" TitleHead="@Translations.Module.Media.Popular" MediaListApi="TmdbDiscoveryApi" CustomExpand="@($"/{Culture}/platform/{Id}/popular/{{0}}")" Culture="@Culture"
                            ShowMovieFilter="ShowMovieFilter" ShowTvFilter="ShowTvFilter" Description="@Translations.Module.Media.PopularDesc.Format(Provider?.name)"
                            StringParameters="@GetExtraParameters(Id, "popularity.desc")" Watching="Watching" Wish="Wish" ForceTypoTitle="Typo.h3" MinQtdItems="12" DetectRegions="true">
        </MediaListComponent>
        <MediaListComponent ContainsHeader="true" TitleHead="@Translations.Module.Media.Release" MediaListApi="TmdbDiscoveryApi" CustomExpand="@($"/{Culture}/platform/{Id}/new/{{0}}")" Culture="@Culture"
                            ShowMovieFilter="ShowMovieFilter" ShowTvFilter="ShowTvFilter" Description="@Translations.Module.Media.NewsDesc.Format(Provider?.name)"
                            StringParameters="@GetExtraParameters(Id, "primary_release_date.desc")" Watching="Watching" Wish="Wish" ForceTypoTitle="Typo.h3" MinQtdItems="12" DetectRegions="true">
        </MediaListComponent>
        <MediaListComponent ContainsHeader="true" TitleHead="@Translations.Module.Media.TopRated" MediaListApi="TmdbDiscoveryApi" CustomExpand="@($"/{Culture}/platform/{Id}/top/{{0}}")" Culture="@Culture"
                            ShowMovieFilter="ShowMovieFilter" ShowTvFilter="ShowTvFilter" Description="@Translations.Module.Media.RecommendedDesc.Format(Provider?.name)"
                            StringParameters="@GetExtraParameters(Id, "vote_average.desc")" Watching="Watching" Wish="Wish" ForceTypoTitle="Typo.h3" MinQtdItems="12" DetectRegions="true">
        </MediaListComponent>
    </RenderControl>

    <FloatingButton Template="Template.Back"></FloatingButton>
}

@code {
    [Parameter] public string? Id { get; set; }
    private bool isNotFound;

    public ComponentActions<ProviderModel?> Actions { get; set; } = new(obj => obj == null);
    private AllProviders? AllProviders { get; set; }
    public ProviderModel? Provider { get; set; }
    private List<EnumFieldObject<Country>> regions = [];

    public WatchingList? Watching { get; set; }
    public WishList? Wish { get; set; }

    public MyProviders? MyProviders { get; set; }
    public SD.Shared.Enums.Platform? Platform { get; set; }
    public SD.Shared.Enums.Country? SelectedRegion { get; set; }

    private bool ShowMovieFilter => Provider?.types.Contains(MediaType.movie) ?? false;
    private bool ShowTvFilter => Provider?.types.Contains(MediaType.tv) ?? false;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        WatchingApi.DataChanged += model => { Watching = model; StateHasChanged(); };
        WishApi.DataChanged += model => { Wish = model; StateHasChanged(); };
    } 

    protected override async Task<bool> LoadInteropDataAsync(Microsoft.JSInterop.IJSRuntime JsRuntime)
    {
        Actions.StartLoading?.Invoke(null);

        AllProviders = await AllProvidersApi.GetAll(null, cts.Token);
        Provider = AllProviders?.Items.SingleOrDefault(s => s.id == Id);
        Platform = await AppStateStatic.GetPlatform(JsRuntime, cts.Token);

        if (Provider == null)
        {
            isNotFound = true;
        }
        else
        {
            regions = EnumHelper.GetList<Country>().Where(p => Provider.regions.Contains(p.Value)).ToList();

            if (AppStateStatic.IsPrerendering(Navigation))
            {
                SelectedRegion = regions.First().Value;
            }
            else
            {
                var temp = await AppStateStatic.GetRegion(IpInfoApi, JsRuntime, cts.Token);
                if (regions.Select(p => p.Value).Contains(temp))
                {
                    SelectedRegion = temp;
                }
            }
        }

        Actions.FinishLoading?.Invoke(Provider);

        return true;
    }

    protected override async Task LoadAuthenticatedDataAsync(CancellationToken token)
    {
        MyProviders = await MyProvidersApi.Get(null, token);

        Watching = await WatchingApi.Get(null, token);
        Wish = await WishApi.Get(null, token);
    }

    private async Task SelectedRegionChanged(Country? value)
    {
        SelectedRegion = value;

        if (value.HasValue)
        {
            await JsRuntime.Utils().SetStorage("region", value.Value.GetFieldSettings(false).Name, JavascriptContext.Default.String, cts.Token);

            AppStateStatic.ChangeRegion(value.Value);
        }
    }

    private Dictionary<string, string> GetExtraParameters(string? providerId, string sortBy)
    {
        if (providerId == null) throw new ArgumentNullException(nameof(providerId));

        return new Dictionary<string, string> {
            { "with_watch_providers", providerId },
            { "sort_by", sortBy },
            { "watch_region", SelectedRegion?.ToString() ?? "NONE" }
        };
    }

    private string? GetSubtitle()
    {
        if (Provider == null) return null;
        var models = string.Join(", ", Provider.models.Select(s => s.GetFieldSettings().Name));
        return $"{Translations.Module.Media.DeliveryModel}: {(models.Empty() ? "null" : models)} | {Translations.Module.Media.Countries}: {Provider.regions.Count}";
    }

    private async Task Add()
    {
        try
        {
            if (!AppStateStatic.IsAuthenticated)
            {
                await ShowWarning(Translations.Notification.YouMustLogged);
                return;
            }

            MyProviders ??= new MyProviders();

            var region = await AppStateStatic.GetRegion(IpInfoApi, JsRuntime, cts.Token);

            var item = new MyProvidersItem { id = Provider?.id, name = Provider?.name, logo = Provider?.logo_path, region = region };
            MyProviders = await MyProvidersApi.Add(MyProviders, item, AppStateStatic.ActiveProduct, ApiContext.Default.MyProvidersItem, cts.Token);

            await ShowSuccess(Translations.Notification.PlatformAdded);
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task Remove()
    {
        try
        {
            if (!AppStateStatic.IsAuthenticated)
            {
                await ShowWarning(Translations.Notification.YouMustLogged);
                return;
            }

            MyProviders ??= new MyProviders();

            MyProviders = await MyProvidersApi.Remove(MyProviders.Items.First(f => f.id == Provider?.id), ApiContext.Default.MyProvidersItem, cts.Token);

            await ShowSuccess(Translations.Notification.PlatformRemoved);
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

}