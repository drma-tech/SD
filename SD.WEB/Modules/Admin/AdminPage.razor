@page "/{culture}/admin"
@attribute [Authorize(Roles = "administrator")]

@using Microsoft.AspNetCore.Authorization
@using SD.WEB.Modules.Auth.Core

@inherits PageCore<AdminPage>
@inject PrincipalImportApi PrincipalImportApi

<MudButton OnClick="ImportHandle">Import Users</MudButton>

@code {
    private async Task ImportHandle()
    {
        try
        {
            var list = await PrincipalImportApi.GetAll(cts.Token);

            foreach (var item in list)
            {
                try
                {
                    await JsRuntime.Supabase().CreateUserAsync(item.UserId, item.Email, item.DisplayName, cts.Token);
                }
                catch (Exception ex)
                {
                    if (ex.Message.Contains("uuid v4 format"))
                    {
                        var newid = await JsRuntime.Supabase().CreateUserAsync(null, item.Email, item.DisplayName, cts.Token);

                        await PrincipalImportApi.Migrate(item.UserId, newid, cts.Token);
                    }
                    else
                    {
                        await ProcessException(ex);
                    }
                }
            }

            await ShowSuccess("import complete");
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }
}
