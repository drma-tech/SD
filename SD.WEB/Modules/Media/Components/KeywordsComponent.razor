@using SD.Shared.Models.List.Tmdb
@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Shared.Core
@inherits ComponentParameterCore<KeywordsComponent>

@inject TmdbSearchKeywordApi TmdbSearchKeywordApi

<RenderControl Actions="Actions" Context="ctx">
    @foreach (var item in List)
    {
        <MudChip T="string" Color="Color.Info" Size="AppStateStatic.Size" OnClick="@(() => Navigation.NavigateTo($"/{Culture}/search?keyword={item.id}"))">
            @item.name
        </MudChip>
    }
</RenderControl>

@code {
    [Parameter][EditorRequired] public string? Culture { get; set; }
    [Parameter][EditorRequired] public string? TmdbId { get; set; }
    [Parameter][EditorRequired] public MediaType? Type { get; set; }

    private ComponentActions<List<TmdbResultKeyword>> Actions { get; set; } = new(lst => lst == null || lst.Empty());

    private List<TmdbResultKeyword> List { get; set; } = [];

    protected override object? GetParameterKey()
    {
        return new
        {
            Type,
            TmdbId
        };
    }

    protected override async Task LoadParameterDataAsync()
    {
        await Actions.StartLoading.Invoke(null);
        if (Type == MediaType.movie)
            List = await TmdbSearchKeywordApi.GetMovieKeywords(TmdbId, cts.Token);
        else
            List = await TmdbSearchKeywordApi.GetSerieKeywords(TmdbId, cts.Token);
        await Actions.FinishLoading.Invoke(List);
    }
}
