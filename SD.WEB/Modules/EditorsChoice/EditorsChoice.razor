@page "/{culture}/editors-choice/{type}"

@inject TmdbListApi TmdbListApi
@inject WatchingListApi WatchingApi
@inject WishListApi WishApi

@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Modules.Profile.Core
@inherits PageCore<EditorsChoice>

<HeadComponent Title="@($"{Translations.Title.EditorsChoice} ({MediaType.GetName()})")" Description="@Translations.Description.EditorsChoice"
               Url="@($"/{Culture}/editors-choice/{Type}")" Index="true" Shared="true"></HeadComponent>
<PageSectionComponent IsPageHeader="true" Title="@($"{Translations.Title.EditorsChoice} ({MediaType.GetName()})")" Subtitle="Top-rated titles for all audiences" Description="@Translations.Description.EditorsChoice"
                      UrlShare="@($"/{Culture}/editors-choice/{Type}")"></PageSectionComponent>

@if (MediaType == MediaType.movie)
{
    <MediaListFull MediaListApi="TmdbListApi" List="@EnumLists.CertifiedStreamingDiscoveryMovies" Watching="Watching" Wish="Wish"
                   FullPage="true" ShowHead="false" Culture="@Culture">
    </MediaListFull>
}
else
{
    <MediaListFull MediaListApi="TmdbListApi" List="@EnumLists.CertifiedStreamingDiscoveryShows" Watching="Watching" Wish="Wish"
                   FullPage="true" ShowHead="false" Culture="@Culture">
    </MediaListFull>
}

@code {
    [Parameter] public string? Type { get; set; }

    public MediaType MediaType => Type.ParseToEnum(MediaType.movie);

    public WatchingList? Watching { get; set; }
    public WishList? Wish { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        WatchingApi.DataChanged += model => { Watching = model; StateHasChanged(); };
        WishApi.DataChanged += model => { Wish = model; StateHasChanged(); };
    }

    protected override async Task LoadAuthDataAsync(CancellationToken token)
    {
        Watching = await WatchingApi.Get(null, token);
        Wish = await WishApi.Get(null, token);
    }

}