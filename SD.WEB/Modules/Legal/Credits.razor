@page "/{culture}/legal/credits"
@inherits PageCore<Credits>

<HeadComponent Title="Credits" Url=@($"/{Culture}/legal/credits") Index="false"></HeadComponent>

<MudGrid Spacing="@Css.SpaceSmall">
    <MudItem xs="12" sm="6">
        <PageSectionComponent IsPageHeader="true" CustomBodyClass="mb-0" Title="TMDB" Subtitle="The Movie Database" Image="logo/tmdb.png" Link="https://www.themoviedb.org"
                        Description="@SD.WEB.Resources.Credit.TMDB">
        </PageSectionComponent>
    </MudItem>
    <MudItem xs="12" sm="6">
        <PageSectionComponent IsPageHeader="true" CustomBodyClass="mb-0" Title="JustWatch" Subtitle="The Streaming Guide" Image="logo/justwatch.png" Link="https://www.justwatch.com"
                        Description="@SD.WEB.Resources.Credit.JustWatch">
        </PageSectionComponent>
    </MudItem>
    <MudItem xs="12" sm="6">
        <PageSectionComponent IsPageHeader="true" CustomBodyClass="mb-0" Title="MudBlazor" Subtitle="Blazor Component Library" Image="logo/mudblazor.png" Link="https://mudblazor.com"
                        Description="@SD.WEB.Resources.Credit.MudBlazor">
        </PageSectionComponent>
    </MudItem>
</MudGrid>
