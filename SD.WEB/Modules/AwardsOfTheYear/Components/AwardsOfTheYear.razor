@page "/{culture}/best-awards-year"

@inject TmdbListApi TmdbListApi
@inject WatchedListApi WatchedApi
@inject WatchingListApi WatchingApi
@inject WishListApi WishApi

@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Modules.Profile.Core
@using SD.WEB.Modules.Collections.Resources
@inherits PageCore<AwardsOfTheYear>

<HeadComponent Title="@Translations.AwardsOfTheYear.Format(DateTime.Now.Year)" Description="@GlobalTranslations.AwardsYearDescription"
               Url=@($"/{Culture}/best-awards-year") Index="true" Shared="true"></HeadComponent>
<PageSectionComponent IsPageHeader="true" Title="@Translations.AwardsOfTheYear.Format(DateTime.Now.Year)" Subtitle="Main categories of the most popular awards" Description="@GlobalTranslations.AwardsYearDescription"
                Icon="@IconsFA.Solid.Icon("trophy").Font" UrlShare="@($"/{Culture}/best-awards-year")"></PageSectionComponent>

<GoogleAdSense Section="@GoogleAdSense.AdUnit.Index"></GoogleAdSense>

<MediaListFull MediaListApi="TmdbListApi" List="@EnumLists.AwardsOfTheYear" Watched="Watched" Watching="Watching" Wish="Wish" Culture="@Culture"
               CommentsIsImage="true" Icon="@IconsFA.Solid.Icon("trophy").Font" FullPage="true" ShowHead="false" Description="@GlobalTranslations.AwardsYearDescription">
</MediaListFull>

@code {
    public WatchedList? Watched { get; set; }
    public WatchingList? Watching { get; set; }
    public WishList? Wish { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        WatchedApi.DataChanged += model => { Watched = model; StateHasChanged(); };
        WatchingApi.DataChanged += model => { Watching = model; StateHasChanged(); };
        WishApi.DataChanged += model => { Wish = model; StateHasChanged(); };
    }

    protected override async Task LoadAuthDataAsync()
    {
        if (AppStateStatic.IsAuthenticated)
        {
            Watched ??= await WatchedApi.Get(true);
            Watching ??= await WatchingApi.Get(true);
            Wish ??= await WishApi.Get(true);
        }
        else
        {
            Watched = null;
            Watching = null;
            Wish = null;
        }
    }

}