@page "/{culture}/best-awards-year"

@inject TmdbListApi TmdbListApi
@inject WatchingListApi WatchingApi
@inject WishListApi WishApi

@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Modules.Profile.Core
@using SD.WEB.Modules.Collections.Resources
@inherits PageCore<AwardsOfTheYear>

<HeadComponent Title="@Translations.AwardsOfTheYear.Format(DateTime.Now.Year)" Description="@GlobalTranslations.AwardsYearDescription"
               Url=@($"/{Culture}/best-awards-year") Index="true" Shared="true"></HeadComponent>
<PageSectionComponent IsPageHeader="true" Title="@Translations.AwardsOfTheYear.Format(DateTime.Now.Year)" Subtitle="Main categories of the most popular awards" Description="@GlobalTranslations.AwardsYearDescription"
                      UrlShare="@($"/{Culture}/best-awards-year")"></PageSectionComponent>

<MediaListFull MediaListApi="TmdbListApi" List="@EnumLists.AwardsOfTheYear" Watching="Watching" Wish="Wish" Culture="@Culture"
               CommentsIsImage="true" FullPage="true" ShowHead="false" Description="@GlobalTranslations.AwardsYearDescription">
</MediaListFull>

@code {
    public WatchingList? Watching { get; set; }
    public WishList? Wish { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        WatchingApi.DataChanged += model => { Watching = model; StateHasChanged(); };
        WishApi.DataChanged += model => { Wish = model; StateHasChanged(); };
    }

    protected override async Task LoadAuthDataAsync(CancellationToken token)
    {
        Watching = await WatchingApi.Get(null, token);
        Wish = await WishApi.Get(null, token);
    }
}