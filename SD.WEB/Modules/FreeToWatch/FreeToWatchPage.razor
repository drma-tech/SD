@page "/{culture}/free/{type}/{region}"

@using SD.WEB.Modules.Collections.Core
@using SD.WEB.Modules.Platform.Resources
@using SD.WEB.Modules.Subscription.Core
@inherits PageCore<FreeToWatchPage>

@inject TmdbDiscoveryApi TmdbDiscoveryApi
@inject IpInfoApi IpInfoApi
@inject IpInfoServerApi IpInfoServerApi

<HeadComponent Title="@(Collections.Resources.Translations.FreeWatchExtended.Format(TypeEnum.GetName(), RegionEnum.GetName()))"
               Description="@Collections.Resources.Translations.FreeWatchDescriptionExtended.Format(TypeEnum.GetName()?.ToLower(), RegionEnum.GetName())"
               Url="@($"/{Culture}/free/{Type}/{Region}")" Index="true" Shared="true"></HeadComponent>
<NewPageSection IsPageHeader="true" Title="@(Collections.Resources.Translations.FreeWatchExtended.Format(TypeEnum.GetName(), RegionEnum.GetName()))"
                Description="@Collections.Resources.Translations.FreeWatchDescriptionExtended.Format(TypeEnum.GetName()?.ToLower(), RegionEnum.GetName())"
                Icon="@IconsFA.Solid.Icon("play-circle").Font" UrlShare="@($"/{Culture}/free/{Type}/{Region}")"></NewPageSection>

<GoogleAdSense Section="@GoogleAdSense.AdUnit.Index"></GoogleAdSense>

@if (TypeEnum == MediaType.movie)
{
    <MediaListFull MediaListApi="TmdbDiscoveryApi" Watched="WatchedList" Watching="WatchingList" Wish="WishList" OnlyYear="true" TypeSelected="MediaType.movie"
                   FullPage="true" ShowHead="false" StringParameters="_extraParameters" Culture="@Culture">
    </MediaListFull>
}
else
{
    <MediaListFull MediaListApi="TmdbDiscoveryApi" Watched="WatchedList" Watching="WatchingList" Wish="WishList" OnlyYear="true" TypeSelected="MediaType.tv"
                   FullPage="true" ShowHead="false" StringParameters="_extraParameters" Culture="@Culture">
    </MediaListFull>
}

@code {
    [Parameter] public string? Type { get; set; }
    [Parameter] public string? Region { get; set; }

    public MediaType TypeEnum => Enum.Parse<MediaType>(Type ?? "movie", true);
    public Region RegionEnum => Enum.Parse<Region>(Region ?? "us", true);

    public WatchedList? WatchedList { get; set; }
    public WatchingList? WatchingList { get; set; }
    public WishList? WishList { get; set; }

    private Dictionary<string, string>? _extraParameters;

    protected override void OnInitialized()
    {
        _extraParameters = GetExtraParameters();
    }

    private Dictionary<string, string> GetExtraParameters()
    {
        return new Dictionary<string, string> { { "sort_by", "popularity.desc" }, { "watch_region", Region?.ToString().ToLower() ?? "us" }, { "with_watch_monetization_types", "ads|free" }, { "vote_average.gte", "6" } };
    }
}