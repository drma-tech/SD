@page "/{culture}/regions"

@inherits PageCore<Regions>

<HeadComponent Title="Regions" Url=@($"/{Culture}/regions") Index="false"></HeadComponent>
<NewPageSection IsPageHeader="true" Icon="@IconsFA.Solid.Icon("globe").Font" Title="Regions"></NewPageSection>

<NewPageSection ShowHeader="false">
    <ActionsFragment>
        <MudSelect Label="Filter" FitContent="!IsMobile" Clearable="true" Dense="true" Class="me-2" Variant="Variant.Text"
                   Value="filter" ValueChanged="@((string? vl) => { filter = vl; StateHasChanged(); })">
            @foreach (var item in Options)
            {
                <MudSelectItem Value="item">@item</MudSelectItem>
            }
        </MudSelect>
    </ActionsFragment>
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
           
            @foreach (var item in GetRegions())
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard>
                        <MudCardHeader Class="pa-2">
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Color="Color.Primary">
                                    @item.GetName()
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardActions Class="pa-2">
                            <MudButton Variant="Variant.Text" Href="@($"/{Culture}/free/movie/{item.ToString().ToLower()}")">
                                @($"Free Movies")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Href="@($"/{Culture}/free/tv/{item.ToString().ToLower()}")">
                                @($"Free Series")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </BodyFragment>
</NewPageSection>

@code {
    public List<Region> RegionsList { get; set; } = [];

    private bool IsMobile => AppStateStatic.Breakpoint <= Breakpoint.Xs;

    private List<string?> Options { get; set; } = [];
    private string? filter;

    protected override async Task ProcessInitialData()
    {
        filter = Culture;

        RegionsList = EnumHelper.GetArray<Region>().ToList();

        Options.Add("en");
        Options.Add("pt");
        Options.Add("es");

        Options.AddRange(RegionsList?.Select(p => p.GetCustomAttribute(false)?.Group).Distinct().ToList() ?? []);
    }

    public List<Region> GetRegions()
    {
        if (filter == "en")
        {
            var english = new HashSet<Region> { Region.US, Region.CA, Region.AU, Region.NZ };

            return RegionsList.Where(p => english.Contains(p) || p.GetCustomAttribute(false)!.Group == "Europe").ToList();
        }
        else if (filter == "pt")
        {
            var portuguese = new HashSet<Region> { Region.BR, Region.PT, Region.AO, Region.MZ, Region.CV };

            return RegionsList.Where(p => portuguese.Contains(p)).ToList();
        }
        else if (filter == "es")
        {
            var spanish = new HashSet<Region> { Region.ES, Region.GQ };

            return RegionsList.Where(p => spanish.Contains(p) || p.GetCustomAttribute(false)!.Group == "Americas").ToList();
        }
        else if (filter.NotEmpty())
        {
            return RegionsList.Where(p => p.GetCustomAttribute(false)?.Group == filter).ToList();
        }
        else
        {
            return RegionsList;
        }
    }
}
