@using SD.WEB.Modules.Auth.Core

@inherits ComponentCore<AccountPopup>

@inject PrincipalApi PrincipalApi

<MudDialog Style="width: 100%; max-height: 70%;">
    <DialogContent>
        <MudTabs Border="true" Outlined="true" TabPanelsClass="pt-2" MinimumTabWidth="100px">
            <MudTabPanel Text="Auth">
                <MudGrid Spacing="@Css.SpaceSmall">
                    <MudItem xs="12">
                        <MudTextField T="@string" Label="@Translations.Module.Profile.AuthProviders" Text="@(string.Join(", ", AppStateStatic.Principal?.AuthProviders ?? []))" Variant="Variant.Filled" ReadOnly="true"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="@string" Label="@Translations.Module.Profile.Identification" Text="@AppStateStatic.Principal?.UserId" Variant="Variant.Filled" ReadOnly="true"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="@string" Label="Display Name" Text="@AppStateStatic.Principal?.DisplayName" Variant="Variant.Filled" ReadOnly="true"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="@string" Label="@Translations.Module.Profile.Email" Text="@AppStateStatic.Principal?.Email" Variant="Variant.Filled" ReadOnly="true"></MudTextField>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Events">
                <MudGrid Spacing="@Css.SpaceSmall">
                    @foreach (var item in AppStateStatic.Principal?.Events ?? [])
                    {
                        <MudItem xs="12" Style="text-align: justify;">
                            <MudPaper Outlined="true" Class="pa-2">
                                <div style="display: flex; gap: 8px; align-items: center;">
                                    <MudText Typo="Typo.subtitle1" Color="Color.Primary">@($"{item?.Origin} | {item?.Date.DateTime.ToLocalTime()}")</MudText>
                                </div>
                                <MudText Typo="Typo.body1" Inline="true"
                                         Style="@($"line-height: normal; line-break: anywhere; {(AppStateStatic.Size == Size.Small ? "font-size: 0.8rem !important;" : "font-size: 1rem !important;")}")">
                                    @item?.Description
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { MudDialog?.Close(); })">
            @Translations.Button.Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    private async Task Logout()
    {
        await JsRuntime.Supabase().SignOutAsync(cts.Token);
    }
}
