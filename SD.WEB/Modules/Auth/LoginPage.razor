@page "/{culture}/auth/login"

@using SD.WEB.Modules.Auth.Core
@using SD.WEB.Modules.Auth.Resources
@using System.Text.RegularExpressions

@inherits PageCore<LoginPage>

@inject PublicLoginApi PublicLoginApi

<HeadComponent Title="@Resources.Translations.SignInSignUp" Description="@Resources.Translations.SignInSignUp" Url=@($"/{Culture}/auth/login") Index="false"></HeadComponent>

<MudContainer MaxWidth="MaxWidth.Small" Class="@Css.Build().Raw("mb-20")">
    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="position: relative;">
        <MudStack Spacing="@Css.SpaceSmall">
            <MudText Typo="Typo.h1" Color="Color.Primary" Class="@Css.Build().Medium("mb")" Style="font-size: 23px !important; line-height: 1.6 !important;" Align="Align.Center">
                @Resources.Translations.SignInSignUp
            </MudText>

            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "google")" Content="@(Button.Recent)" Overlap="true">
                <MudButton Variant="Variant.Filled" OnClick="LoginWithGoogle" StartIcon="@IconsFA.Brands.Icon("google").Font" Disabled="@(Platform == SD.Shared.Enums.Platform.ios || _processingInProgress)" FullWidth="true">
                    <MudText>@Resources.Translations.ContinueWith.Format("Google")</MudText>
                </MudButton>
            </MudBadge>
            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "apple")" Content="@(Button.Recent)" Overlap="true">
                <MudButton Variant="Variant.Filled" OnClick="LoginWithApple" StartIcon="@IconsFA.Brands.Icon("apple").Font" Disabled="@_processingInProgress" FullWidth="true">
                    <MudText>@Resources.Translations.ContinueWith.Format("Apple")</MudText>
                </MudButton>
            </MudBadge>
            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "microsoft")" Content="@(Button.Recent)" Overlap="true">
                <MudButton Variant="Variant.Filled" OnClick="LoginWithMicrosoft" StartIcon="@IconsFA.Brands.Icon("microsoft").Font" Disabled="@_processingInProgress" FullWidth="true">
                    <MudText>@Resources.Translations.ContinueWith.Format("Microsoft")</MudText>
                </MudButton>
            </MudBadge>
            <MudDivider Class="@Css.Build().Medium("my")"></MudDivider>
            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "email")" Content="@(Button.Recent)" Overlap="true">
                <MudTextField @bind-Value="@email" Label="@Resources.Translations.Email" Placeholder="@Resources.Translations.EnterEmail" Disabled="@(_processingInProgress || emailProbablySent)" Immediate="true"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Send" OnAdornmentClick="() => LoginWithEmail(email)"
                              HelperText="@Resources.Translations.MicrosoftEmails" Variant="Variant.Outlined"></MudTextField>
            </MudBadge>
            @if (SuggestEmailCorrection(email).NotEmpty())
            {
                <MudAlert Variant="Variant.Outlined" Dense="true" Severity="Severity.Warning">
                    @SuggestEmailCorrection(email)
                </MudAlert>
            }
            <MudTextField @ref="@txtOTP" @bind-Value="@otp" Label="@Resources.Translations.OTPCode" Placeholder="@Resources.Translations.EnterCode" Disabled="@(!emailProbablySent)"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Check" OnAdornmentClick="() => ConfirmCode(email, otp)"
                          HelperText="@Resources.Translations.EmailDelay" Variant="Variant.Outlined"></MudTextField>
        </MudStack>
        <div style="text-align: center;">
            <MudText Class="@Css.Build().Large("mt").Medium("mb")">
                @((MarkupString)string.Format(Translations.Terms1, $"<a href='/{Culture}/legal/terms' target='_blank' rel='noopener' class='mud-link mud-primary-text mud-link-underline-hover'>{SD.WEB.Modules.Help.Resources.Translations.TermsUse}</a>", $"<a href='/{Culture}/legal/privacy' target='_blank' rel='noopener' class='mud-link mud-primary-text mud-link-underline-hover'>{SD.WEB.Modules.Help.Resources.Translations.PrivacyPolicy}</a>"))
            </MudText>
        </div>
        <MudOverlay Visible="_processingInProgress" DarkBackground="true" Absolute="true" Style="text-align: center;">
            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
            <MudText Color="Color.Secondary">@GlobalTranslations.OperationProgress</MudText>
        </MudOverlay>
    </MudPaper>
</MudContainer>

<style>
    .mud-badge.mud-badge-top.right.mud-badge-overlap {
        inset: auto auto calc(100% - 16px) calc(100% - 30px) !important;
    }
</style>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string? email;
    private string? otp;
    private bool emailProbablySent;
    private MudTextField<string>? txtOTP;

    private async Task LoginWithGoogle() => await SignIn("google");
    private async Task LoginWithApple() => await SignIn("apple");
    private async Task LoginWithMicrosoft() => await SignIn("microsoft");
    private async Task LoginWithEmail(string? email) => await SignIn("email", email);

    private SD.Shared.Enums.Platform? Platform { get; set; }
    private bool _processingInProgress = false;
    private string? lastUsedProvider = null;

    protected override async Task ProcessPopupData()
    {
        Platform = await AppStateStatic.GetPlatform(JsRuntime);
        lastUsedProvider = await JsRuntime.Utils().GetStorage<string>("auth-last-used");
    }

    private async Task SignIn(string? provider = null, string? email = null)
    {
        var success = false;
        var reference = Guid.NewGuid().ToString("N");

        try
        {
            _processingInProgress = true;

            await JsRuntime.Utils().SetStorage<AuthProvider>("auth", AuthProvider.Supabase);
            await JsRuntime.Utils().SetStorage("auth-last-used", provider);

            if (provider == "email")
            {
                if (!IsValidEmail(email ?? ""))
                {
                    await ShowError(Resources.Translations.EnterEmail);
                    _processingInProgress = false; StateHasChanged();
                    return;
                }

                await PublicLoginApi.SendEmail(email, reference);
                success = true;
            }
            else
            {
                if (provider == "microsoft") provider = "azure";
                await JsRuntime.Supabase().SignInAsync(provider!, ReturnUrl);
                success = true;
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
            _processingInProgress = false; StateHasChanged();
        }
        finally
        {
            if (success)
            {
                await Task.Delay(provider == "email" ? 8000 : 20000);
                if (provider == "email") emailProbablySent = true;
            }

            _processingInProgress = false;
            StateHasChanged();

            if (provider == "email" && success)
            {
                await txtOTP!.FocusAsync();
                _ = MonitorEmailStatus(reference);
            }
        }
    }

    private async Task MonitorEmailStatus(string reference)
    {
        try
        {
            for (int i = 0; i < 12 && !_processingInProgress; i++)
            {
                var message = await PublicLoginApi.StatusEmail(reference);

                if (message.NotEmpty())
                {
                    await ShowError(message);
                    emailProbablySent = false;
                    StateHasChanged();
                    break;
                }

                if (_processingInProgress) break;

                await Task.Delay(5000);
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled | RegexOptions.IgnoreCase);

    private static bool IsValidEmail(string? email)
    {
        if (email.Empty()) return false;

        return EmailRegex.IsMatch(email);
    }

    private async Task ConfirmCode(string? email = null, string? code = null)
    {
        try
        {
            _processingInProgress = true;

            if (code.Empty())
            {
                await ShowError(Resources.Translations.EnterCode);
                _processingInProgress = false; StateHasChanged();
                return;
            }

            await JsRuntime.Supabase().ConfirmCode(email!, code!);

            Navigation.NavigateTo($"/{Culture}");
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
            _processingInProgress = false; StateHasChanged();
        }
        finally
        {
            await Task.Delay(5000);
            _processingInProgress = false;
        }
    }

    private static readonly HashSet<string> KnownDomains = new(StringComparer.OrdinalIgnoreCase) { "gmail.com", "hotmail.com", "outlook.com", "yahoo.com" };

    public static string? SuggestEmailCorrection(string? email)
    {
        if (email.Empty()) return null;

        var parts = email.Split('@');
        if (parts.Length != 2)
            return null;

        var local = parts[0];
        var domain = parts[1];

        if (KnownDomains.Contains(domain))
            return null;

        // Find closest match
        var closest = KnownDomains
            .Select(d => new { Domain = d, Distance = StringHelper.Levenshtein(domain, d) })
            .OrderBy(x => x.Distance)
            .First();

        // Threshold to avoid bad suggestions
        if (closest.Distance <= 2)
            return $"Did you mean {local}@{closest.Domain}?";

        return null;
    }

}
