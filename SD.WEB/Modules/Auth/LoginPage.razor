@page "/{culture}/auth/login"

@using SD.WEB.Modules.Auth.Core
@using System.Text.RegularExpressions

@inherits PageCore<LoginPage>

@inject PublicLoginApi PublicLoginApi

<HeadComponent Title="@Translations.Module.Auth.SignInSignUp" Description="@Translations.Module.Auth.SignInSignUp" Url=@($"/{Culture}/auth/login") Index="false"></HeadComponent>

<MudContainer MaxWidth="MaxWidth.Small" Class="@Css.Build().Raw("mb-20")">
    <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="position: relative;">
        <MudStack Spacing="@Css.SpaceSmall">
            <MudText Typo="Typo.h1" Color="Color.Primary" Class="@Css.Build().Medium("mb")" Style="font-size: 23px !important; line-height: 1.6 !important;" Align="Align.Center">
                @Translations.Module.Auth.SignInSignUp
            </MudText>

            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "google")" Content="@(Translations.Button.Recent)" Overlap="true">
                <MudButton Variant="Variant.Filled" OnClick="LoginWithGoogle" StartIcon="@Icons.Custom.Brands.Google" Disabled="@(Platform == SD.Shared.Enums.Platform.ios || _processingInProgress)"
                           FullWidth="true" Color="Color.Primary">
                    <MudText>@Translations.Module.Auth.ContinueWith.Format("Google")</MudText>
                </MudButton>
            </MudBadge>
            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "apple")" Content="@(Translations.Button.Recent)" Overlap="true">
                <MudButton Variant="Variant.Filled" OnClick="LoginWithApple" StartIcon="@Icons.Custom.Brands.Apple" Disabled="@_processingInProgress" FullWidth="true" Color="Color.Primary">
                    <MudText>@Translations.Module.Auth.ContinueWith.Format("Apple")</MudText>
                </MudButton>
            </MudBadge>
            <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "microsoft")" Content="@(Translations.Button.Recent)" Overlap="true">
                <MudButton Variant="Variant.Filled" OnClick="LoginWithMicrosoft" StartIcon="@Icons.Custom.Brands.Microsoft" Disabled="@_processingInProgress" FullWidth="true" Color="Color.Primary">
                    <MudText>@Translations.Module.Auth.ContinueWith.Format("Microsoft")</MudText>
                </MudButton>
            </MudBadge>
            <MudDivider Class="@Css.Build().Medium("my")"></MudDivider>
            <MudToolBar Gutters="false" Style="height: auto;">
                <MudBadge Color="Color.Warning" Visible="@(lastUsedProvider == "email")" Content="@(Translations.Button.Recent)" Overlap="true" Style="width: 100%;" Class="me-5">
                    <MudTextField @bind-Value="@email" Label="@Translations.Module.Auth.ContinueWith.Format(SD.WEB.Translations.Module.Auth.Email)" Placeholder="@Translations.Module.Auth.EnterEmail" Disabled="@(_processingInProgress || emailProbablySent)"
                                  Immediate="true" InputType="InputType.Email" HelperText="@Translations.Module.Auth.MicrosoftEmails" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                </MudBadge>
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" Variant="Variant.Filled" OnClick="() => LoginWithEmail(email)"
                               Style="align-self: start; margin-top: 8px;" Disabled="@(_processingInProgress || emailProbablySent)" />
            </MudToolBar>
            @if (SuggestEmailCorrection(email).NotEmpty())
            {
                <MudAlert Variant="Variant.Outlined" Dense="true" Severity="Severity.Warning">
                    @SuggestEmailCorrection(email)
                </MudAlert>
            }
            <MudToolBar Gutters="false" Style="height: auto;">
                <MudTextField @ref="@txtOTP" @bind-Value="@otp" Label="@Translations.Module.Auth.OTPCode" Placeholder="@Translations.Module.Auth.EnterCode" Disabled="@(!emailProbablySent)"
                              InputType="InputType.Number" HelperText="@Translations.Module.Auth.EmailDelay" Variant="Variant.Outlined" Margin="Margin.Dense" Class="me-5" />
                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Variant="Variant.Filled" OnClick="() => ConfirmCode(email, otp)"
                               Style="align-self: start; margin-top: 8px;" Disabled="@(!emailProbablySent)" />
            </MudToolBar>
        </MudStack>
        <div style="text-align: center;" class="@Css.Build().Large("mt").Medium("mb")">
            <MudIcon Icon="@Icons.Material.Filled.CheckBox" Size="Size.Small" Style="vertical-align: sub;" />
            <MudText Inline="true">
                @((MarkupString)string.Format(Translations.Module.Auth.Terms1, $"<a href='/{Culture}/legal/terms' target='_blank' rel='noopener' class='mud-link mud-primary-text mud-link-underline-hover'>{Translations.Module.Legal.TermsUse}</a>", $"<a href='/{Culture}/legal/privacy' target='_blank' rel='noopener' class='mud-link mud-primary-text mud-link-underline-hover'>{Translations.Module.Legal.PrivacyPolicy}</a>"))
            </MudText>
        </div>
        <MudOverlay Visible="_processingInProgress" DarkBackground="true" Absolute="true" Style="text-align: center;">
            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
            <MudText Color="Color.Secondary">@Translations.Notification.OperationProgress</MudText>
        </MudOverlay>
    </MudPaper>
</MudContainer>

<style>
    .mud-badge.mud-badge-top.right.mud-badge-overlap {
        inset: auto auto calc(100% - 16px) calc(100% - 30px) !important;
    }
</style>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string? email;
    private string? otp;
    private bool emailProbablySent;
    private MudTextField<string>? txtOTP;

    private async Task LoginWithGoogle() => await SignIn("google");
    private async Task LoginWithApple() => await SignIn("apple");
    private async Task LoginWithMicrosoft() => await SignIn("microsoft");
    private async Task LoginWithEmail(string? email) => await SignIn("email", email);

    private SD.Shared.Enums.Platform? Platform { get; set; }
    private bool _processingInProgress = false;
    private string? lastUsedProvider = null;

    protected override async Task ProcessPopupData()
    {
        Platform = await AppStateStatic.GetPlatform(JsRuntime, cts.Token);
        lastUsedProvider = await JsRuntime.Utils().GetStorage("auth-last-used", JavascriptContext.Default.String, cts.Token);
    }

    private async Task SignIn(string? provider = null, string? email = null)
    {
        var success = false;
        var reference = Guid.NewGuid().ToString("N");

        try
        {
            _processingInProgress = true;

            await JsRuntime.Utils().SetStorage<AuthProvider>("auth", AuthProvider.Supabase, JavascriptContext.Default.AuthProvider, cts.Token);
            await JsRuntime.Utils().SetStorage("auth-last-used", provider, JavascriptContext.Default.String, cts.Token);

            if (provider == "email")
            {
                if (!IsValidEmail(email ?? ""))
                {
                    await ShowError(Translations.Module.Auth.EnterEmail);
                    _processingInProgress = false; StateHasChanged();
                    return;
                }

                await PublicLoginApi.SendEmail(email, reference, cts.Token);
                success = true;
            }
            else
            {
                if (provider == "microsoft") provider = "azure";
                await JsRuntime.Supabase().SignInAsync(provider!, ReturnUrl, cts.Token);
                success = true;
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
            _processingInProgress = false; StateHasChanged();
        }
        finally
        {
            if (success)
            {
                await Task.Delay(provider == "email" ? 6000 : 20000);
                if (provider == "email") emailProbablySent = true;
            }

            _processingInProgress = false;
            StateHasChanged();

            if (provider == "email" && success)
            {
                await ShowInfo(Translations.Module.Auth.CodeSent.Format(email));
                await txtOTP!.FocusAsync();
                _ = MonitorEmailStatus(reference);
            }
        }
    }

    private async Task MonitorEmailStatus(string reference)
    {
        try
        {
            for (int i = 0; i < 12 && !_processingInProgress; i++)
            {
                var message = await PublicLoginApi.StatusEmail(reference, cts.Token);

                if (message.NotEmpty())
                {
                    await ShowError(message);
                    emailProbablySent = false;
                    StateHasChanged();
                    break;
                }

                if (_processingInProgress || cts.IsCancellationRequested) break;

                await Task.Delay(5000);
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled | RegexOptions.IgnoreCase);

    private static bool IsValidEmail(string? email)
    {
        if (email.Empty()) return false;

        return EmailRegex.IsMatch(email);
    }

    private async Task ConfirmCode(string? email = null, string? code = null)
    {
        try
        {
            _processingInProgress = true;

            if (code.Empty())
            {
                await ShowError(Translations.Module.Auth.EnterCode);
                _processingInProgress = false; StateHasChanged();
                return;
            }

            await JsRuntime.Supabase().ConfirmCode(email!, code!, cts.Token);

            Navigation.NavigateTo($"/{Culture}");
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
            _processingInProgress = false; StateHasChanged();
        }
        finally
        {
            await Task.Delay(5000);
            _processingInProgress = false;
        }
    }

    private static readonly HashSet<string> KnownDomains = new(StringComparer.OrdinalIgnoreCase) { "gmail.com", "hotmail.com", "outlook.com", "yahoo.com" };

    public static string? SuggestEmailCorrection(string? email)
    {
        if (email.Empty()) return null;

        var parts = email.Split('@');
        if (parts.Length != 2)
            return null;

        var local = parts[0];
        var domain = parts[1];

        if (KnownDomains.Contains(domain))
            return null;

        // Find closest match
        var closest = KnownDomains
            .Select(d => new { Domain = d, Distance = StringHelper.Levenshtein(domain, d) })
            .OrderBy(x => x.Distance)
            .First();

        // Threshold to avoid bad suggestions
        if (closest.Distance <= 2)
            return $"Did you mean {local}@{closest.Domain}?";

        return null;
    }

}
