@page "/login"

@using SD.WEB.Core.Auth
@using SD.WEB.Modules.Auth.Resources
@using SD.WEB.Modules.Subscription.Core
@using System.Text.RegularExpressions

@inherits PageCore<LoginPage>

<SeoMeta Title="Sign In or Sign Up" Description="Sign In or Sign Up" Url="/login" Index="false"></SeoMeta>

<MudContainer MaxWidth="MaxWidth.Small" Class="@Css.Build().Raw("mb-20")">
    <MudPaper Elevation="0" Outlined="true" Class="pa-3">
        <MudStack Spacing="@Css.SpaceSmall">
            <MudText Typo="Typo.h1" Color="Color.Primary" Class="@Css.Build().Medium("mb")" Style="font-size: 23px !important; line-height: 1.6 !important;" Align="Align.Center">
                Sign In or Sign Up
            </MudText>

            <MudButton Variant="Variant.Filled" OnClick="LoginWithGoogle" StartIcon="@IconsFA.Brands.Icon("google").Font" Disabled="@(Platform == SD.Shared.Enums.Platform.ios || _processing)">
                @if (_processing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processing</MudText>
                }
                else
                {
                    <MudText>Continue with Google</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Filled" OnClick="LoginWithApple" StartIcon="@IconsFA.Brands.Icon("apple").Font" Disabled="@_processing">
                @if (_processing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processing</MudText>
                }
                else
                {
                    <MudText>Continue with Apple</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Filled" OnClick="LoginWithMicrosoft" StartIcon="@IconsFA.Brands.Icon("microsoft").Font" Disabled="@_processing">
                @if (_processing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processing</MudText>
                }
                else
                {
                    <MudText>Continue with Microsoft</MudText>
                }
            </MudButton>
            <MudDivider Class="@Css.Build().Medium("my")"></MudDivider>
            <MudTextField @bind-Value="@email" Label="Email" Placeholder="Enter your email" Disabled="@(_processing || emailSent)" Immediate="true"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Send" OnAdornmentClick="() => LoginWithEmail(email)"
                          HelperText="Microsoft emails (Outlook, Hotmail, etc.) may not work."></MudTextField>
            @if (SuggestEmailCorrection(email).NotEmpty())
            {
                <MudAlert Variant="Variant.Outlined" Dense="true" Severity="Severity.Warning">
                    @SuggestEmailCorrection(email)
                </MudAlert>
            }
            <MudTextField @bind-Value="@otp" Label="OTP Code" Placeholder="Enter the code you received by email." Disabled="@(!emailSent)"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Check" OnAdornmentClick="() => ConfirmCode(email, otp)"></MudTextField>
        </MudStack>
        <div style="text-align: center;">
            <MudText Class="@Css.Build().Large("mt").Medium("mb")">
                @((MarkupString)string.Format(Translations.Terms1, $"<a href='support/terms' target='_blank' class='mud-link mud-primary-text mud-link-underline-hover'>{SD.WEB.Modules.Support.Resources.Translations.TermsUse}</a>", $"<a href='support/privacy' target='_blank' class='mud-link mud-primary-text mud-link-underline-hover'>{SD.WEB.Modules.Support.Resources.Translations.PrivacyPolicy}</a>"))
            </MudText>
        </div>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string? email;
    private string? otp;
    private bool emailSent;

    private async Task LoginWithGoogle() => await SignIn("google");
    private async Task LoginWithApple() => await SignIn("apple");
    private async Task LoginWithMicrosoft() => await SignIn("microsoft");
    private async Task LoginWithX() => await SignIn("x");
    private async Task LoginWithYahoo() => await SignIn("yahoo");
    private async Task LoginWithEmail(string? email) => await SignIn("email", email);

    private SD.Shared.Enums.Platform? Platform { get; set; }
    private bool _processing = false;

    protected override async Task ProcessPopupData()
    {
        Platform = await AppStateStatic.GetPlatform(JsRuntime);
    }

    private async Task SignIn(string? provider = null, string? email = null)
    {
        var success = false;

        try
        {
            _processing = true;

            await JsRuntime.Utils().SetStorage<AuthProvider>("auth", AuthProvider.Supabase);

            if (provider == "email")
            {
                if (!IsValidEmail(email ?? ""))
                {
                    await ShowError("Please enter a valid email.");
                    _processing = false; StateHasChanged();
                    return;
                }

                await JsRuntime.Supabase().SendEmailAsync(email!);
                success = true;
            }
            else
            {
                if (provider == "microsoft") provider = "azure";
                await JsRuntime.Supabase().SignInAsync(provider!, ReturnUrl);
                success = true;
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
            _processing = false; StateHasChanged();
        }
        finally
        {
            if (success)
            {
                await Task.Delay(8000);
                emailSent = true;
            }

            _processing = false;
            StateHasChanged();
        }
    }

    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled | RegexOptions.IgnoreCase);

    private static bool IsValidEmail(string? email)
    {
        if (email.Empty()) return false;

        return EmailRegex.IsMatch(email);
    }

    private async Task ConfirmCode(string? email = null, string? code = null)
    {
        try
        {
            _processing = true;

            if (code.Empty())
            {
                await ShowError("Please enter the code you received by email.");
                _processing = false; StateHasChanged();
                return;
            }

            await JsRuntime.Supabase().ConfirmCode(email!, code!);

            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
            _processing = false; StateHasChanged();
        }
        finally
        {
            await Task.Delay(5000);
            _processing = false;
        }
    }

    private static readonly HashSet<string> KnownDomains = new(StringComparer.OrdinalIgnoreCase) { "gmail.com", "hotmail.com", "outlook.com", "yahoo.com" };

    public static string? SuggestEmailCorrection(string? email)
    {
        if (email.Empty()) return null;

        var parts = email.Split('@');
        if (parts.Length != 2)
            return null;

        var local = parts[0];
        var domain = parts[1];

        if (KnownDomains.Contains(domain))
            return null;

        // Find closest match
        var closest = KnownDomains
            .Select(d => new { Domain = d, Distance = StringHelper.Levenshtein(domain, d) })
            .OrderBy(x => x.Distance)
            .First();

        // Threshold to avoid bad suggestions
        if (closest.Distance <= 2)
            return $"Did you mean {local}@{closest.Domain}?";

        return null;
    }

}
