@page "/{culture}/help"
@inherits PageCore<HelpCenter>

@using SD.WEB.Layout
@using SD.WEB.Modules.Auth.Core
@using SD.WEB.Modules.Profile.Core

@inject PrincipalApi PrincipalApi
@inject MyProvidersApi MyProvidersApi
@inject MySuggestionsApi MySuggestionsApi
@inject WatchedListApi WatchedListApi
@inject WatchingListApi WatchingListApi
@inject WishListApi WishListApi
@inject LoginApi LoginApi

<HeadComponent Title="@SeoTranslations.HelpCenter" Description="@SeoTranslations.HelpCenterDesc.Format(AppInfo.Title)" Url=@($"/{Culture}/help") Index="true"></HeadComponent>
<PageSectionComponent IsPageHeader="true" Icon="@IconsFA.Solid.Icon("headset").Font" Title="@SeoTranslations.HelpCenter" Description="@SeoTranslations.HelpCenterDesc.Format(AppInfo.Title)"></PageSectionComponent>

<PageSectionComponent Title="Quick Actions">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Window().InvokeVoidAsync("eval", "Userback && Userback.openForm('general', 'form');"); })">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("comment").Font"></MudIcon>
                    Feedback
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="mailto:support@streamingdiscovery.com">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("at").Font"></MudIcon>
                    Contact Support
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/help/faq")>
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("question-circle").Font"></MudIcon>
                    Browse FAQ
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/compare")>
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("question-circle").Font"></MudIcon>
                    @SeoTranslations.Compare
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Troubleshooting">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Utils().ShowCache(); })">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("database").Font"></MudIcon>
                    @Button.ShowCache
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Utils().ClearAllStorage(); })">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("trash-alt").Font"></MudIcon>
                    @Button.ClearCache
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/regions")>
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("globe").Font"></MudIcon>
                    Browse by Region
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Account">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@DownloadData" Disabled="Principal == null">
                    Download Data
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@DeleteAccount" Disabled="Principal == null">
                    @SD.WEB.Modules.Profile.Resources.Translations.DeleteAccount
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Legal & Privacy">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/legal/terms") Rel="nofollow">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("file-contract").Font"></MudIcon>
                    @WEB.Modules.Help.Resources.Translations.TermsUse
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/legal/privacy") Rel="nofollow">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("user-shield").Font"></MudIcon>
                    @WEB.Modules.Help.Resources.Translations.PrivacyPolicy
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/legal/credits") Rel="nofollow">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("users").Font"></MudIcon>
                    @WEB.Modules.Help.Resources.Translations.Credits
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Get the App">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            @foreach (var store in AppInfo.Stores)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudButton Variant="Variant.Filled" FullWidth="true" Href="@store.Url" Target="_blank" rel="noopener">
                        <MudImage Src="@store.Logo" Class="me-2" Style="width: 20px; vertical-align: top;" Alt="@store.Store" />
                        @store.Store
                    </MudButton>
                </MudItem>
            }
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Company">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/company/about-us")>
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("building").Font"></MudIcon>
                    About us
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="mailto:contact@drma-tech.com">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("at").Font"></MudIcon>
                    Contact us
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="https://www.drma-tech.com" Target="_blank" rel="noopener">
                    <MudIcon Class="me-2" Icon="@IconsFA.Solid.Icon("globe").Font"></MudIcon>
                    Website
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="More from DRMA Tech">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            @foreach (var product in AppInfo.Products)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudButton Variant="Variant.Filled" FullWidth="true" Href="@product.Url" Target="_blank" rel="noopener">
                        <MudImage Src="@product.Logo" Class="me-2" Style="width: 20px; vertical-align: top;" Alt="@product.Title" />
                        @product.Title
                    </MudButton>
                </MudItem>
            }
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

@code {
    private AuthPrincipal? Principal { get; set; }

    protected override async Task ProcessPopupData()
    {
        Principal = await PrincipalApi.Get(AppStateStatic.IsAuthenticated, true);
    }

    private async Task DownloadData()
    {
        try
        {
            if (Principal == null) return;

            var data = new SuperData() { Principal = Principal };

            var sub = Principal.GetActiveSubscription();

            data.Login = await LoginApi.Get(AppStateStatic.IsAuthenticated);
            data.Providers = await MyProvidersApi.Get(AppStateStatic.IsAuthenticated);
            if (sub?.ActiveProduct is null or AccountProduct.Basic) data.Suggestions = null;
            else data.Suggestions = await MySuggestionsApi.Get(sub?.ActiveProduct, AppStateStatic.IsAuthenticated);
            data.WatchedList = await WatchedListApi.Get(AppStateStatic.IsAuthenticated);
            data.WatchingList = await WatchingListApi.Get(AppStateStatic.IsAuthenticated);
            data.WishList = await WishListApi.Get(AppStateStatic.IsAuthenticated);

            var fileName = $"{AppInfo.Title.ToSlug()}_{Principal.AuthProviders[0]}_{DateTime.UtcNow:yyyyMMdd_HHmmss}.json";
            await JsRuntime.Utils().DownloadFile(fileName, "application/json", data.ConvertFromObjectToBytes());
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task DeleteAccount()
    {
        try
        {
            if (Principal == null) return;

            if (Principal.GetActiveSubscription() != null)
            {
                await DialogService.ShowMessageBoxAsync("You still have an active subscription", "Please cancel your subscription before deleting your profile.");
                return;
            }

            if (await DialogService.ShowMessageBoxAsync(AppInfo.Title, GlobalTranslations.SureDeleteAccount, Button.Ok, Button.Cancel) ?? false)
            {
                //remove data from cosmos db
                await PrincipalApi.Remove();

                //TODO: remove data from supabase table

                //close current login session
                await Logout();
            }
            else
            {
                await ShowInfo(GlobalTranslations.OperationCanceled);
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task Logout()
    {
        await JsRuntime.Supabase().SignOutAsync();
    }
}
