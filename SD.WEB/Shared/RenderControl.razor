@using SD.WEB.Shared.Core

@typeparam T where T : class

<div class="@Class">
    @if (Actions.CurrentStatus == RenderStatus.Loading)
    {
        <div style="position: relative;">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="@LoadingHeight" Animation="Animation.Wave" />
            <span style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-weight: 500;">
                @Translations.Notification.RenderControlLoading
            </span>
        </div>
    }
    else if (Actions.CurrentStatus == RenderStatus.Error)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.BugReport" Style="text-align: justify;">
            @(Actions.MessageError ?? Translations.Notification.RenderControlInvalid)
        </MudAlert>
    }
    else if (PremiumFeature && !IsPremium)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Diamond" Style="text-align: justify;">
            <span class="me-2" style="font-weight: bold;">@Translations.Notification.PremiumFeature</span>
            @if (!string.IsNullOrEmpty(Actions.CustomPremiumDescription))
            {
                @Actions.CustomPremiumDescription
            }
        </MudAlert>
    }
    else if (PrivateFeature && !IsAuthenticated)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lock" Style="text-align: justify;">
            @Translations.Module.Auth.UnauthenticatedUser
        </MudAlert>
    }
    else if (Actions.CurrentStatus == RenderStatus.Warning)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Warning" Style="text-align: justify;">
            @(Actions.MessageWarning ?? Translations.Notification.RenderControlNoData)
        </MudAlert>
    }
    else //Content
    {
        @if (Actions.CurrentInstance == null || Actions.ExpressionEmpty(Actions.CurrentInstance))
        {
            if (HideIfEmpty)
            {
                <div></div>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Warning" Style="text-align: justify;">
                    @Translations.Notification.RenderControlNoData
                </MudAlert>
            }
        }
        else
        {
            @ChildContent(Actions.CurrentInstance)
        }
    }
</div>

@code {
    [Parameter][EditorRequired] public ComponentActions<T> Actions { get; set; } = null!;
    [Parameter][EditorRequired] public RenderFragment<T> ChildContent { get; set; } = null!;

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? LoadingHeight { get; set; } = "230px";

    [Parameter] public bool PrivateFeature { get; set; }
    [Parameter] public bool IsAuthenticated { get; set; }

    [Parameter] public bool PremiumFeature { get; set; }
    [Parameter] public bool IsPremium { get; set; }

    [Parameter] public bool HideIfEmpty { get; set; }

    protected override void OnInitialized()
    {
        Actions.OnStateChanged += StateHasChanged;
    }
}
