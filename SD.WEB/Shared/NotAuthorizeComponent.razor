@inherits BaseComponentCore<NotAuthorizeComponent>

<PageTitle>401 - Not Authorized</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex" />
</HeadContent>

<style>
    body {
        margin: 0;
        font-family: sans-serif;
    }

    .container {
        height: calc(100vh - 64px - 32px - 48px - 24px);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }
</style>

<div class="container">
    <div>
        <MudText Typo="Typo.h4" Color="Color.Primary">@Translations.Module.Auth.UnauthenticatedUser</MudText>
        <MudText Typo="Typo.h6">@Translations.Module.Auth.YouMustLogged</MudText>
        <div class="@Css.Build().Large("mt")">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Login" Class="me-3" Size="AppStateStatic.Size">
                @Translations.Button.Login
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Default" Href=@($"/{Culture}") Size="AppStateStatic.Size">
                Return to homepage
            </MudButton>
        </div>
    </div>
</div>

@code {
    private string Culture => Navigation.GetCulture();

    protected override void OnInitialized()
    {
        AppStateStatic.HideAdvertising.Publish(true);
    }

    private async Task Login()
    {
        Navigation.NavigateTo($"/{Culture}/auth/login?returnUrl={Uri.EscapeDataString(Navigation.Uri.Split('#')[0])}");
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            AppStateStatic.HideAdvertising.Publish(false);
        }

        base.Dispose(disposing);
    }
}
